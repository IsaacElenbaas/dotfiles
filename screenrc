# the mouse option breaks things - click to select works, but scrolling just sends escape codes and enabling vim mouse support at the same time makes escape wait forever regardless of maptimeout

shell "/usr/bin/zsh"
# ew
vbell off
startup_message off
# makes fullscreen applications clear
altscreen on
# don't remember why I had this as screen-256color but xterm fixes ctrl+arrows in vim and nothing seems to be broken
term xterm-256color
maptimeout 5

#{{{ keybinds
# showkey -a
escape "^Aa"

	#{{{ broken keybinds
markkeys "\^=\201"
markkeys "$=\205"
# unfortunately c-left and c-right aren't possible without lots of Xresources shenanigans and something to feed them normally here
	#}}}

bindkey "^[G" windowlist
# ctrl shift r
bindkey "^[R" title
bindkey "^[D" remove
# ctrl return
bindkey "^[Q" screen
# ctrl shift s
bindkey "^[^V" copy
bindkey -m " " eval 'stuff \40' "writebuf" "exec bash -c 'cat /tmp/screen-exchange | xsel -b'"

	#{{{ navigation
bindkey "^[H" focus left
bindkey "^[T" focus down
bindkey "^[C" focus up
bindkey "^[N" focus right
bindkey "^[L" prev
# ctrl backspace
bindkey "^[\177" next
bindkey "^['" focus next
bindkey "^[," focus prev
	#}}}

	#{{{ frames
bindkey "^[M" eval "split" "focus next"
bindkey "^[S" eval "split -v" "focus next"
bindkey "^[V" resize -h -12
bindkey "^[E" resize -v -6
bindkey "^[." resize -v +6
bindkey "^[U" resize -h +12

bindkey "^[B" eval "split" "focus next" "resize 20%" "screen 1"
	#}}}
#}}}
