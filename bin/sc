#!/bin/bash

div=" \033[0m|\033[1m "

[ -n "$VIM_TERMINAL" ] && printf '\033]51;["call", "Tapi_sc", []]\a' # for terminal in vim, see vimrc
[ -n "$STY" ] && screen -X -S "${STY%%.*}" source ~/.screenrcunbind
export IFS=
printf "\033[?25l" # hide cursor
index=99
scrollFrom=0
scrollTo=0
while true; do
	sockets="$(
		screen -ls | while IFS= read -r line; do
			[ "${line: -10}" = "(Detached)" ] && {
				line="${line:0:-10}"
				line="${line#${line%%[![:space:]]*}}"; line="${line%${line##*[![:space:]]}}"
				printf "%s\n" "$line"
			}
		done | tac
	)"
	if [ "$sockets" == "" ]; then
		printf "No detached Sockets found.\n"
		[ -n "$STY" ] && screen -X -S "${STY%%.*}" source ~/.screenrc
		[ -n "$VIM_TERMINAL" ] && printf '\033]51;["call", "Tapi_scEnd", []]\a' # for terminal in vim, see vimrc
		exit 0
	fi
	maxIndex=$(printf "%s" "$sockets" | wc -l)
	[ $index -le $maxIndex ] || index=$maxIndex
	[ $scrollFrom -le $index ] || scrollFrom=$index
	[ $scrollTo -ge $index ] || scrollTo=$index
	scrollFrom=$(((index-scrollFrom)-(LINES-2) < 0 ? scrollFrom : index-(LINES-2)+1))
	scrollTo=$(((LINES-2)+scrollFrom-scrollTo > 0 ? scrollTo : scrollFrom+(LINES-2)-1))
	i=0
	while read -r line; do
		[ $i -ge $scrollFrom ] || { i=$((i+1)); continue; }
		[ $i -le $scrollTo ] || break
		cpid="${line%%.*}"
		line="${line#*.}"
		[ "${line:0:4}" = "pts-" ] && line="$cpid.$line"
		if [ $i -eq $index ]; then
			printf "\033[7m%s\033[0m\n" "$line"
			pid=$cpid
			name="$line"
		else
			printf "%s\n" "$line"
		fi
		i=$((i+1))
	done <<< "$sockets"
	printf "\033[1mq/Esc:quit${div}CR:restore${div}d:delete${div}r:rename${div}p/Space:preview\033[0m\n"
	read -rs -N 1 key
	read -rs -N 99 -t 0.005 key2
	key2="$key$key2"
	while [ -n "$key2" ]; do
		if [ "${key2::1}" = $'\033' ]; then
			key2="${key2:1}"
			key=$'\033'"${key2%%$'\033'*}"
			key2="${key2#*$'\033'}"
		else
			key="${key2:0:1}"
			key2="${key2:1}"
		fi
		case "$key" in
			$'\033[A')
				index=$((index>0 ? index-1 : 0))
			;;
			$'\033[B')
				index=$((index < maxIndex ? index+1 : maxIndex))
			;;
			"g")
				index=0
			;;
			"G")
				index=$maxIndex
			;;
			"q" | $'\033')
				printf "\033[?25h" # restore cursor
				[ -n "$STY" ] && screen -X -S "${STY%%.*}" source ~/.screenrc
				[ -n "$VIM_TERMINAL" ] && printf '\033]51;["call", "Tapi_scEnd", []]\a' # for terminal in vim, see vimrc
				exit
			;;
			$'\n')
				screen -d -r $pid
				exit 1
			;;
			"d")
				[ "${name:0:4}" = "pts-" ] && line="$pid.$name"
				REPLY=
				printf "\033[?25h"
				while [ "$REPLY" != "yes" ] && [ "$REPLY" != "no" ]; do printf "\033[A\033[K"; read -p "Are you sure you want to kill '$name'? [yes/no]: "; done
				printf "\033[?25l"
				[ "$REPLY" = "yes" ] && { screen -X -S $pid quit; scrollFrom=$((scrollFrom <= 0 ? 0 : scrollFrom-1)); scrollTo=$((scrollTo-1)); printf "\033[A\033[K"; }
			;;
			"r")
				printf "\033[?25h"
				read -r -p "New name: "
				printf "\033[A\033[K\033[?25l"
				screen -X -S $pid sessionname "$REPLY"
			;;
			" "|"p")
				screen -X -S $pid bindkey "q" detach
				screen -d -r $pid &>/dev/null
				screen -X -S $pid bindkey "q"
				printf "\033[A\033[K"
			;;
		esac
	done
	for (( i=-2; i < scrollTo-scrollFrom; i++ )); do
		printf "\033[A\033[K"
	done
done
