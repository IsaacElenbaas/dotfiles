#!/bin/bash

systemctl is-active --user --quiet xpra-server || { printf "xpra-server is not running!\n" >&2; exit 1; }

while true; do
	read -p "Enable GPU? (y/n): "
	{ [ "$REPLY" = "y" ] || [ "$REPLY" = "n" ]; } && break
	printf "\033[A\r\033[K"
done
sudo -v || exit 1

journalctl _SYSTEMD_INVOCATION_ID="$(systemctl --user show --value -p InvocationID xpra-server)" -q -o cat -f --no-tail | grep -m 1 "xpra is ready" > /dev/null
trap "" SIGINT
touch /tmp/xpra-restartx
while true; do
	systemctl is-active --user --quiet xpra-server || { printf "xpra-server failed!\n" >&2; exit 1; }
	[ -f /tmp/xpra-restartx ] || break
	kill -0 $p_sudo &>/dev/null || {
		sudo -v || exit 1
		while true; do
			sudo -n true || break
			sleep 180
			kill -0 $$ &>/dev/null || break
		done &
		p_sudo=$!
	}
	if [ "$REPLY" = "n" ]; then
		startx || { sudo -K; exit 1; }
		REPLY="y"
	else
		nvidia-xrun ~/.xinitrc || { sudo -K; exit 1; }
		REPLY="n"
	fi
done
sudo -K
