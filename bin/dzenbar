#!/bin/bash

export h="$1"
div=" ‖ "

#{{{ functions
	#{{{ tagText
		#{{{ tag indicator box sizes
ts1=$(($h/4))
ts2=$(($h/2))
ts3_t=$(($h/10))
ts3=$(($ts2-2*$ts3_t))
		#}}}

tagText() {
	local text="^p(_LOCK_X)^p($ts1;$ts1)^ib(1)"
	for (( i=$1; i<$t; i=($i+$m) )); do
		if [ "$i" = "$2" ]; then
			text="$text^p(-$ts1;-$ts1)^r(${h}x$h)^p($ts1;$ts1)^fg(black)^r(${ts2}x$ts2)^p($h)^fg()"
		else
			text="$text^r(${ts2}x$ts2)^p($ts3_t;$ts3_t)^fg(black)^r(${ts3}x$ts3)^p(-$ts3_t;-$ts3_t)^p($h)^fg()"
		fi
	done
	printf "$text^p(_UNLOCK_X)"
}
	#}}}
#}}}

#{{{ setup
export m=$(herbstclient get_attr monitors.count)
t=$(herbstclient get_attr tags.count)
primary="$(xrandr --query | grep "connected[[:space:]]primary[[:space:]][[:digit:]]" || xrandr --query | grep "[[:space:]]connected[[:space:]][[:digit:]]")"
# just in case
primary="${primary#*[[:space:]]}"
primary="${primary%%(*}"
primary="${primary%${primary##*[![:space:]]}}"
primary="${primary##*[[:space:]]}"
primaryW="${primary%%x*}"
for (( i=0; i<$m; i++ )); do
	[ "$(herbstclient get_attr monitors.$i.geometry)" = "$primary" ] && primary=$i && break
done

	#{{{ tag setup
declare -a mProcs
declare -a tags
for (( i=0; i<$m; i++ )); do
	herbstclient pad $i $h
	coproc dzen2 {
		read -d "x" w
		read -d "+" x
		read -d "+" x
		read y
		cat -u | dzen2 -fn "DejaVu" -ta l -e '' -p -x $x -y $y -h $h
	}
	herbstclient get_attr monitors.$i.geometry >&"${dzen2[1]}"
	# this is illegal but works at the moment so. . .
	mProcs+=(${dzen2[1]}); unset dzen2
	tags+=(-1)
done
	#}}}
#}}}

#{{{ timers
{
	watch -n 1 -pt "herbstclient emit_hook time" &
	watch -n 10 -t "herbstclient emit_hook status" &
	watch -n $((60*60*60)) -t "herbstclient emit_hook updates" &
# was giving me garbage characters and lots of newlines
} &>/dev/null
#}}}

#{{{ updating variables
while IFS= read -r line; do
	update=0
	monitor=
	case "${line%${line##*[![:space:]]}}" in
		"song")
			mocp="$(mocp --format '%tl %song')"
			# pause play will for sure have this run again before song ends, that sets again to right time (so pause/play doesn't call this)
			# skip/prev will call this as old could come in after new song ends
			songTrigger="${mocp%% *}"
			if [ "$songTrigger" != "" ]; then
				songTrigger="$((SECONDS+10#${songTrigger%:*}*60+10#${songTrigger#*:}+1))"
				title="${mocp#* }"
			else
				songTrigger=0
				title="----------------"
			fi
			[ "$title" != "$dzsong" ] && dzsong="$title" && update=1
		;;
		"updates")
			dzupdates="$({ checkupdates; yay -Qu; } | wc -l)"
			updateplural=$([ "$dzupdates" = "1" ] && printf "" || printf "s")
			update=1
		;;
		"status")
			dzstatus="$(free | awk '/Mem/ { printf "%d%% RAM", ($2-$7)/$2*100; }')"
			if [ -d /sys/class/power_supply/BAT0 ]; then
				dzstatus="$dzstatus$div$(cat /sys/class/power_supply/BAT0/status) "
				charge="$((10000*10/8*$(cat /sys/class/power_supply/BAT0/charge_now)/$(cat /sys/class/power_supply/BAT0/charge_full)))"
				dzstatus="$dzstatus${charge:: -2}.${charge: -2}%"
			fi
			update=1
		;;
		"volume") dzvol="$(awk -F "[][]" '/\[/ { print $2; exit; }' <(amixer sget Master))"; update=1 ;;
		"time")
			dzdate="$(date +'%a %d %b %r')"
			[ "${songTrigger:-0}" -ne 0 ] && [ "$SECONDS" -ge "$songTrigger" ] && herbstclient emit_hook song || update=1
		;;
		"tag_changed"*)
			tag="${line#*[[:space:]]}"
			tag="${tag#${tag%%[![:space:]]*}}"
			tag="${tag%[[:space:]]*}"
			monitor="${line##*[[:space:]]}"
			monitor="${monitor#${monitor%%[![:space:]]*}}"
			if [ "${tags[$monitor]}" != "$tag" ]; then
				update=2
				tagTexts[$monitor]="$(tagText $monitor $tag)"
			fi
			tags[$monitor]=$tag
		;;
		"focus_changed"*"0x0")
			herbstclient chain , lock , and : compare tags.focus.curframe_wcount = 0 : set_layout horizontal , unlock
		;;
	esac
	case $update in
		0) ;;
		*)
			monitor="${monitor:-$primary}"
			printf "%s" "${tagTexts[$monitor]}" >&"${mProcs[$monitor]}"
			if [ $monitor = $primary ]; then
				printf "%s" "^pa(0;0)^ba($primaryW,_RIGHT)$div$dzsong$div$dzupdates update$updateplural$div$dzstatus$div$dzvol$div$dzdate$div" >&"${mProcs[$primary]}"
			fi
			printf "\n" >&"${mProcs[$monitor]}"
		;;
	esac
done < <(
	for (( i=0; i<$m; i++ )); do
		tag="$(herbstclient get_attr monitors.$i.tag)"
		printf "tag_changed ${tag%$'\n'} $i\n"
		printf "tag_changed ${tag%$'\n'} $i\n" >&2
	done
	printf "volume\nsong\nstatus\nupdates\n"
	herbstclient -i
)
#}}}
