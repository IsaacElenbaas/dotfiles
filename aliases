#!/bin/bash

alias CAPSLOCK='xdotool key Caps_Lock'
alias c='clear'
alias cp='cp -ri'
alias ctl='systemctl'
alias detach='[ -n "$STY" ] && screen -X -S "${STY%%.*}" detach'
alias dirsize='du -sh -- .'
