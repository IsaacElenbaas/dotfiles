#!/usr/bin/bash

mocp -x
youtube-dl --download-archive /home/isaacelenbaas/Music/archive.txt "https://www.youtube.com/playlist?list=PL9aQR0qi3yRad5s3ABdKaC06M9g1O0Iem" -f 'bestaudio/best' --extract-audio --audio-format mp3 --metadata-from-title "%(id)s" --add-metadata -o "/home/isaacelenbaas/Music/%(title)s.%(ext)s" --no-overwrites
find /home/isaacelenbaas/Music/ -name "*\\.mp3" -exec mp3gain -r -k -c {} \;
mocp --server 2>/dev/null
mocp --toggle shuffle --append /home/isaacelenbaas/Music 2>/dev/null

