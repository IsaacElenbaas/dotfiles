#!/usr/bin/bash

ln -sf ~/dotfiles/Xresources               ~/.Xresources
ln -sf ~/dotfiles/bash_profile             ~/.bash_profile
ln -sf ~/dotfiles/bashrc                   ~/.bashrc
ln -sf ~/dotfiles/fff                      ~/.fff
ln -sf ~/dotfiles/inputrc                  ~/.inputrc
ln -sf ~/dotfiles/mutt/muttrc              ~/.muttrc
ln -sf ~/dotfiles/profile                  ~/.profile
ln -sf ~/dotfiles/screenrc                 ~/.screenrc
ln -sf ~/dotfiles/screenrcunbind           ~/.screenrcunbind
ln -sf ~/dotfiles/tmux.conf                ~/.tmux.conf
ln -sf ~/dotfiles/vim                      ~/.vim
ln -sf ~/dotfiles/vimrc                    ~/.vimrc
ln -sf ~/dotfiles/xbindkeysrc              ~/.xbindkeysrc
ln -sf ~/dotfiles/xinitrc                  ~/.xinitrc
ln -sf ~/dotfiles/zsh                      ~/.zsh
ln -sf ~/dotfiles/zshrc                    ~/.zshrc

mkdir -p ~/.config
ln -sf ~/dotfiles/cleanup                  ~/.config/
ln -sf ~/dotfiles/herbstluftwm             ~/.config/
ln -sf ~/dotfiles/navi                     ~/.config/
mkdir -p ~/.config/dunst
ln -sf ~/dotfiles/dunstrc                  ~/.config/dunst/
mkdir -p ~/.config/mpv
ln -sf ~/dotfiles/mpv.conf                 ~/.config/mpv/
ln -sf ~/dotfiles/mpvbinds.conf            ~/.config/mpv/input.conf
mkdir -p ~/.config/neofetch
ln -sf ~/dotfiles/neofetch.conf            ~/.config/neofetch/config.conf
mkdir -p ~/.config/pipewire
ln -sf ~/dotfiles/pipewire-pulse.conf      ~/.config/pipewire/
mkdir -p ~/.config/qutebrowser
ln -sf ~/dotfiles/qutebrowser/config.py    ~/.config/qutebrowser/
mkdir -p ~/.config/systemd
ln -sf ~/dotfiles/systemd                  ~/.config/systemd/user

mkdir -p ~/.local/share
ln -sf ~/dotfiles/icons                    ~/.local/share/
ln -sf ~/dotfiles/fonts                    ~/.local/share/
ln -sf ~/dotfiles/navi                     ~/.local/share/
mkdir -p ~/.local/share/qutebrowser
ln -sf ~/dotfiles/qutebrowser/greasemonkey ~/.local/share/qutebrowser/
ln -sf ~/dotfiles/qutebrowser/userscripts  ~/.local/share/qutebrowser/

mkdir -p ~/.xpra
ln -sf ~/dotfiles/xpra.conf                ~/.xpra/

sudo chown root:root ~/dotfiles/bin/power
sudo ln -sf ~/dotfiles/systemd/power.service /etc/systemd/system/
sudo systemctl enable power

# git config here so I don't have to worry about accidentally pushing .gitconfig sensitive info
git config --global core.editor "vim"
git config --global core.pager "diff-so-fancy | less -x2 -RFX"
git config --global init.defaultbranch "master"
git config --global pull.rebase true
git config --global user.email "isaacelenbaas@gmail.com"
git config --global user.name "IsaacElenbaas"

sudo bash -c 'for i in /usr/lib/python3*/site-packages/qutebrowser; do
	cd "$i" &>/dev/null
	{ [ -d "./.git" ] && [ "$(git status -s | wc -l)" = 0 ]; } && exit
	rm -rf .git
	git init &>/dev/null
	git checkout -b hint_escape_bind_fixes
	git add -A &>/dev/null
	git config user.email "isaacelenbaas@gmail.com"
	git config user.name "IsaacElenbaas"
	git commit -m "base" --no-gpg-sign &>/dev/null
	git remote add upstream https://github.com/qutebrowser/qutebrowser.git &>/dev/null
	git fetch upstream master pull/6821/head:pr/6821
	git replace --graft "$(git log upstream/master..pr/6821 --reverse --format=format:%H | head -n 1)~1"
	git checkout "$(git replace)" &>/dev/null
	git switch -c pr/6821_trimmed &>/dev/null
	git cherry-pick $(git log upstream/master..pr/6821 --reverse --format=format:%H) &>/dev/null
	FILTER_BRANCH_SQUELCH_WARNING=1 git filter-branch --subdirectory-filter qutebrowser &>/dev/null
	git checkout hint_escape_bind_fixes &>/dev/null
	git cherry-pick $(git log pr/6821_trimmed --reverse --format=format:%H | { IFS= read -r; cat; })
done'
