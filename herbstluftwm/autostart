#!/usr/bin/bash

#{{{ init
hc () {
	herbstclient "$@"
}
hc emit_hook reload
hc keyunbind --all
hc unrule -F
hc set_attr theme.tiling.reset 1
m=$(hc get_attr monitors.count)
for (( i=0; i<$m; i++ )); do
	hc remove_monitor $i
done
hc detect_monitors
m=$(hc get_attr monitors.count)
h=20
Mod=Mod4 # Use the super key as the main modifier
#}}}

#{{{ autostart
hc set auto_detect_monitors 0
#pacwall.sh -b "#232831" -d "#e5e9f080" -e "#88c0d0" -s "#c5c8c626"
xsetroot
xrdb ~/.Xresources
#}}}

#{{{ keybindings
hc keybind $Mod-Shift-q quit
hc keybind $Mod-Shift-r reload
hc keybind $Mod-a spawn ~/Projects/Launcher/launcher.py
hc keybind $Mod-d spawn bash -c "[ \$(herbstclient get_attr tags.focus.curframe_wcount) -gt 0 ] && saveclose $h || herbstclient remove"

	#{{{ launching commonly used
		#{{{ no vim terminal
# if reactivating this remember to change shell in screenrc
#hc keybind $Mod-Return spawn xterm -e "screen"
#hc keybind $Mod-Shift-Return spawn xterm -e "screen bash -c 'f; [ -n \"\$STY\" ] && screen -X -S \"\${STY%%.*}\" chdir \"\$(pwd)\"; exec zsh -l'"
#hc keybind $Mod-Shift-v spawn xterm -e "screen bash -c 'vim; exec zsh -l'"
		#}}}

		#{{{ vim terminal
vimTerm() {
	# autocommands aren't triggered for some reason
	printf "%s" "screen vim -c 'execute '\\''augroup TermStart'\\''.\"\\n\".'\\''autocmd VimEnter * call Terminal() | noswapfile call term_start($1, {\"term_finish\":\"close\", \"curwin\":1, \"norestore\":1}) | execute \"autocmd! TermStart\"'\\''.\"\\n\".'\\''augroup END'\\'''"
}
# unfortunately can't put vim around screen because it can't go back more than one page (for obvious reasons). Whatever, only an extra ~5MB of RAM wasted per additional screen item.
hc keybind $Mod-Return spawn xterm -e "$(vimTerm "[\"zsh\", \"-l\"]")"
hc keybind $Mod-Shift-Return spawn xterm -e "$(vimTerm "[\"bash\", \"-c\", \"f; [ -n \\\"\\\$STY\\\" ] && screen -X -S \\\"\\\${STY%%.*}\\\" chdir \\\"\\\$(pwd)\\\"; exec zsh -l\"]")"
hc keybind $Mod-Shift-v spawn xterm -e "$(vimTerm "[\"bash\", \"-c\", \"vim; exec zsh -l\"]")"
		#}}}

# this won't save layout but prevents breaking due to resize
hc keybind $Mod-Shift-m spawn xterm -e "herbstclient fullscreen on; exec mocp -T ~/dotfiles/mocp-theme"
	#}}}

	#{{{ navigation
hc keybind $Mod-h focus left
hc keybind $Mod-t focus down
hc keybind $Mod-c focus up
hc keybind $Mod-n focus right
hc keybind $Mod-apostrophe cycle 1
hc keybind $Mod-comma cycle -1
hc keybind $Mod-g \
	chain , lock , set_attr theme.border_width 8 , spawn /usr/share/doc/herbstluftwm/examples/maximize.sh grid , keybind Left focus left , keybind Down focus down , keybind Up focus up , keybind Right focus right , keybind Return chain . lock . set_attr theme.border_width 3 . spawn /usr/share/doc/herbstluftwm/examples/maximize.sh grid . keyunbind Left . keyunbind Down . keyunbind Up . keyunbind Right . keyunbind Return . unlock , unlock

		#{{{ tags
hc keybind $Mod-l use_index -$m
hc keybind $Mod-BackSpace use_index +$m
		#}}}
	#}}}

	#{{{ layouts
hc keybind $Mod-f spawn fullscreen
hc keybind $Mod-Shift-f chain , or . and : compare clients.focus.fullscreen = false : spawn fullscreen full . spawn fullscreen , fullscreen toggle
hc keybind $Mod-space cycle_layout 1 horizontal vertical max
	#}}}

	#{{{ clients
hc keybind $Mod-Shift-h or / shift left / \
	chain , lock , shift_to_monitor -l , focus_monitor -l , unlock
hc keybind $Mod-Shift-t shift down
hc keybind $Mod-Shift-c shift up
hc keybind $Mod-Shift-n or / shift right / \
	chain , lock , shift_to_monitor -r , focus_monitor -r , unlock
hc keybind $Mod-y spawn bash -c "herbstclient setenv clip \$(herbstclient get_attr clients.focus.winid)"
hc keybind $Mod-i spawn bash -c "herbstclient bring \$(herbstclient getenv clip)"
	#}}}

	#{{{ frames
hc keybind $Mod-m chain , split bottom 0.5 , focus down
hc keybind $Mod-s chain , split right  0.5 , focus right
resizestep=0.05
hc keybind $Mod-o      resize left  +$resizestep
hc keybind $Mod-e      resize down  +$resizestep
hc keybind $Mod-period resize up    +$resizestep
hc keybind $Mod-u      resize right +$resizestep
	#}}}
#}}}

#{{{ tag setup
default_frame_layout horizontal
hc rename default "0"
for (( i=1; i<6*$m; i++ )); do
	hc add "$i"
done
t=$(hc get_attr tags.count)
for (( i=6*$m; i<$t; i++ )); do
	hc merge_tag $i 0
done
for (( i=0; i<$m; i++ )); do
	hc chain , focus_monitor $i , use_index $i
done
#}}}

#{{{ theme
	#{{{ colors
hc set frame_border_normal_color "#2C2C2C"
hc set frame_border_active_color "#383838"
hc set_attr theme.inner_color black # between border and window
hc set_attr theme.active.color "#009fbc"
hc set_attr theme.normal.color "#454545"
hc set_attr theme.urgent.color "#EF9C00"
	#}}}

	#{{{ sizes
hc set frame_border_width 3
hc set window_gap 3
hc set frame_padding 0 # between inner and window
hc set_attr theme.border_width 3
hc set_attr theme.inner_width 1 # between border and window
	#}}}

hc set always_show_frame 1
hc set frame_bg_transparent 1 # solid vs border frame
hc set smart_frame_surroundings true
hc set mouse_recenter_gap 99999
#}}}

#{{{ rules
hc rule focus=on ewmhrequests=off ewmhnotify=off fullscreen=off # normally focus new clients, don"t allow them to control their fullscreen or "needs attention" state, and don't tell them what's going on
hc rule windowtype~"_NET_WM_WINDOW_TYPE_(DIALOG|UTILITY|SPLASH)" pseudotile=on
hc rule windowtype~"_NET_WM_WINDOW_TYPE_(NOTIFICATION|DOCK|DESKTOP)" manage=off
hc rule class="discord" tag=2
hc rule class="Steam" tag=3
hc rule class="Steam" not title="Steam" focus=off
hc rule class="mpv" not title="noMin" focus=off index="/"
#}}}

#{{{ misc/bar startup
hc set tree_style "╾│ ├└╼─┐" # For printing window list
# copied from dzenbar
primary="$(xrandr --query | grep "connected[[:space:]]*primary")"
# just in case
primary="${primary#*[[:space:]]}"
primary="${primary%%(*}"
primary="${primary%${primary##*[![:space:]]}}"
primary="${primary##*[[:space:]]}"
for (( i=0; i<$m; i++ )); do
	[ "$(herbstclient get_attr monitors.$i.geometry)" = "$primary" ] && primary=$i && break
done
hc focus_monitor $primary
hc unlock
ps -o pgid,cmd -U "$USER" | grep "[d]zenbar" | while IFS= read -r line; do line="${line#${line%%[![:space:]]*}}" && pkill -g "${line%%[[:space:]]*}"; done
dzenbar $h &
#}}}
